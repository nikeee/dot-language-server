{
  "name": "dot-language-server",
  "version": "3.0.6",
  "description": "Language server for the DOT language",
  "keywords": [
    "dot",
    "graphviz",
    "gv",
    "language",
    "lsp",
    "protocol",
    "server"
  ],
  "license": "MIT",
  "author": "Niklas Mollenhauer",
  "repository": {
    "type": "git",
    "url": "https://github.com/nikeee/dot-language-server.git"
  },
  "bin": {
    "dot-language-server": "dist/cli.mjs"
  },
  "type": "module",
  "scripts": {
    "build": "tsc && tsdown",
    "ci": "oxlint --type-check --type-aware -f github",
    "format": "oxfmt",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix",
    "test": "tsc --noEmit",
    "smoketest": "node --run build && node --test",
    "prepublishOnly": "node --run clean && node --run build"
  },
  "dependencies": {
    "dot-language-support": "^4.1.4",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "@tsdown/exe": "^0.21.8",
    "@types/node": "^25.6.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "oxlint-tsgolint": "^0.20.0",
    "rimraf": "^6.1.3",
    "tsdown": "^0.21.8",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=22"
  }
}
